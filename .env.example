# Supabase Configuration
# 비밀번호 특수문자 URL 인코딩 적용: + → %2B, & → %26, * → %2A
# Transaction Pooler (port 6543) 사용 — Supabase 권장 방식
DATABASE_URL="postgresql://user:password@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct URL (마이그레이션 및 직접 연결용)
DIRECT_URL="postgresql://user:password@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# API Keys (for client-side or admin tasks if needed later)
SUPABASE_URL="https://example.supabase.co"
SUPABASE_ANON_KEY="your-anon-key-here"

# OpenAI API Key for Smart Analysis
OPENAI_API_KEY="sk-your-openai-api-key"

# Yahoo Finance API Key (Optional / For RapidAPI)
# 현재 사용하는 yahoo-finance2 라이브러리는 무료 모드(Scraping)로 작동하므로 비워두셔도 됩니다.
# 만약 RapidAPI 등의 유료 API를 사용할 경우 여기에 입력하세요.
YAHOO_FINANCE_API_KEY=""

# Twitter API V2
TWITTER_BEARER_TOKEN="your-twitter-bearer-token"
TWITTER_API_KEY="your-twitter-api-key"
TWITTER_API_SECRET="your-twitter-api-secret"

# Admin API Key (관리자 기능 활성화용)
ADMIN_API_KEY="your-admin-api-key"

# Server Port
PORT=3000
